---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const slugs = [...new Set(posts.map(p => p.data.categorySlug))];

  return slugs.map(slug => {
    const filtered = posts.filter(p => p.data.categorySlug === slug);
    return {
      params: { category: slug },
      props: {
        posts: filtered.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
        categoryName: filtered[0].data.category,
      },
    };
  });
}

const { posts, categoryName } = Astro.props;
---
<Layout title={`${categoryName} — МойБлог`}>
  <a href="/" class="back-link">← Все статьи</a>

  <h1 class="page-title">{categoryName}</h1>
  <p class="page-subtitle">{posts.length} {posts.length === 1 ? 'статья' : 'статьи'}</p>

  <div class="posts-grid">
    {posts.map(post => {
      const date = post.data.pubDate.toLocaleDateString('ru-RU', {
        day: 'numeric',
        month: 'long',
        year: 'numeric',
      });
      return (
        <article class="post-card">
          <h2><a href={`/blog/${post.id}`}>{post.data.title}</a></h2>
          <p>{post.data.description}</p>
          <span class="meta">{date}</span>
        </article>
      );
    })}
  </div>
</Layout>
