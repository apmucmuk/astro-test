---
import { categoryLabels, typeLabels, audienceLabels } from '../lib/labels';

interface Props {
  id: string;
  title: string;
  description: string;
  pubDate: Date;
  category: string;
  type: string;
  audience: string;
  stage: string;
}

const { id, title, description, pubDate, category, type, audience } = Astro.props;

const dateStr = pubDate.toLocaleDateString('pl-PL', {
  day: 'numeric', month: 'long', year: 'numeric',
});
---

<article class="post-card">
  <div class="card-badges">
    <span class="badge badge--category">{categoryLabels[category] ?? category}</span>
    <span class="badge badge--type">{typeLabels[type] ?? type}</span>
    <span class="badge badge--audience">{audienceLabels[audience] ?? audience}</span>
  </div>

  <h2 class="card-title">
    <a href={`/blog/${id}`}>{title}</a>
  </h2>

  <p class="card-desc">{description}</p>

  <footer class="card-footer">
    <time datetime={pubDate.toISOString()} class="card-date">{dateStr}</time>
    <a href={`/blog/${id}`} class="card-link" aria-label={`Czytaj: ${title}`}>
      Czytaj artykuł →
    </a>
  </footer>
</article>

<style>
  .post-card {
    background: var(--clr-bg);
    border: 1px solid var(--clr-border);
    border-radius: var(--radius-lg);
    padding: var(--sp-6);
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
    transition: box-shadow 0.2s, transform 0.2s;
  }
  .post-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .card-badges { display: flex; flex-wrap: wrap; gap: var(--sp-2); }

  .card-title {
    font-size: var(--text-xl);
    font-weight: 700;
    line-height: 1.3;
  }
  .card-title a {
    color: var(--clr-text);
    text-decoration: none;
  }
  .card-title a:hover { color: var(--clr-primary); }

  .card-desc {
    color: var(--clr-text-muted);
    font-size: var(--text-base);
    line-height: 1.6;
    flex: 1;
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--sp-3);
    padding-top: var(--sp-4);
    border-top: 1px solid var(--clr-border);
  }

  .card-date {
    font-size: var(--text-sm);
    color: var(--clr-text-muted);
  }

  .card-link {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--clr-accent);
    text-decoration: none;
  }
  .card-link:hover { text-decoration: underline; }
</style>
